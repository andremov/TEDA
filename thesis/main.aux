\@writefile{lof}{\contentsline {figure}{\numberline {4.23}{\ignorespaces Extrapolated per-cycle estimation cost as a function of state dimension $n$ for $N_e = 80$, anchored to the measured Lorenz~96 timings at $n = 40$. Log-log axes. The $\mathcal  {O}(n^3)$ methods (direct precision shrinkage, Ledoit-Wolf after inversion) scale as a straight line of slope~3; EnKF-Cholesky with bandwidth $r = 2$ scales linearly in $n$; NERCOME carries an additional factor of $B = 200$ throughout. The vertical dashed lines mark regimes of interest: laboratory-scale ($n \approx 40$, where we ran experiments), mid-scale testbeds ($n \approx 10^3$, e.g.\ quasi-geostrophic models), and operational NWP ($n \approx 10^6$).}}{61}{figure.caption.62}\protected@file@percent }
\newlabel{fig:timing_scaling}{{4.23}{61}{Extrapolated per-cycle estimation cost as a function of state dimension $n$ for $N_e = 80$, anchored to the measured Lorenz~96 timings at $n = 40$. Log-log axes. The $\mathcal {O}(n^3)$ methods (direct precision shrinkage, Ledoit-Wolf after inversion) scale as a straight line of slope~3; EnKF-Cholesky with bandwidth $r = 2$ scales linearly in $n$; NERCOME carries an additional factor of $B = 200$ throughout. The vertical dashed lines mark regimes of interest: laboratory-scale ($n \approx 40$, where we ran experiments), mid-scale testbeds ($n \approx 10^3$, e.g.\ quasi-geostrophic models), and operational NWP ($n \approx 10^6$)}{figure.caption.62}{}}
\@writefile{lot}{\contentsline {table}{\numberline {4.5}{\ignorespaces Method recommendation by regime. ``Target known'' means a structural prior on the precision matrix is available (e.g., the cosmological $2/N_\ell $ term for power spectrum data). ``Dense'' and ``near-diagonal'' refer to the dominant off-diagonal structure of the true precision.}}{61}{table.caption.63}\protected@file@percent }
\newlabel{tab:method_recommendation}{{4.5}{61}{Method recommendation by regime. ``Target known'' means a structural prior on the precision matrix is available (e.g., the cosmological $2/N_\ell $ term for power spectrum data). ``Dense'' and ``near-diagonal'' refer to the dominant off-diagonal structure of the true precision}{table.caption.63}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.24}{\ignorespaces Time-averaged relative RMSE ($\times 10^{-2}$) for all eight methods on the AR(1) cosmological model at $N_e = 30$. Error bars show $\pm 1$ standard deviation over 30 runs. Ledoit-Wolf achieves the lowest RMSE; the direct precision methods are competitive but do not lead.}}{62}{figure.caption.64}\protected@file@percent }
\newlabel{fig:cosmo_enkf_bar}{{4.24}{62}{Time-averaged relative RMSE ($\times 10^{-2}$) for all eight methods on the AR(1) cosmological model at $N_e = 30$. Error bars show $\pm 1$ standard deviation over 30 runs. Ledoit-Wolf achieves the lowest RMSE; the direct precision methods are competitive but do not lead}{figure.caption.64}{}}
\@writefile{lot}{\contentsline {table}{\numberline {4.6}{\ignorespaces Cross-domain summary. Best standalone estimator and best EnKF filter for each domain. The disconnect between estimation quality and filtering performance is the central finding.}}{62}{table.caption.65}\protected@file@percent }
\newlabel{tab:cross_domain}{{4.6}{62}{Cross-domain summary. Best standalone estimator and best EnKF filter for each domain. The disconnect between estimation quality and filtering performance is the central finding}{table.caption.65}{}}
