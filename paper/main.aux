\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Extrapolated per-cycle estimation cost as a function of state dimension $n$ for $N_e = 80$, anchored to the measured Lorenz~96 timing at $n = 40$. Log-log axes. The $\mathcal  {O}(n^3)$ methods (direct precision shrinkage, Ledoit--Wolf after inversion) scale with slope~3; EnKF-Cholesky with bandwidth $r = 2$ scales linearly in $n$; NERCOME carries an additional factor of $B = 200$ throughout. Vertical dashed lines mark testbed ($n \approx 40$), intermediate testbeds ($n \approx 10^3$), and operational NWP ($n \approx 10^6$).}}{19}{figure.1.8}\protected@file@percent }
\newlabel{fig:timing_scaling}{{8}{19}{Extrapolated per-cycle estimation cost as a function of state dimension $n$ for $N_e = 80$, anchored to the measured Lorenz~96 timing at $n = 40$. Log-log axes. The $\mathcal {O}(n^3)$ methods (direct precision shrinkage, Ledoit--Wolf after inversion) scale with slope~3; EnKF-Cholesky with bandwidth $r = 2$ scales linearly in $n$; NERCOME carries an additional factor of $B = 200$ throughout. Vertical dashed lines mark testbed ($n \approx 40$), intermediate testbeds ($n \approx 10^3$), and operational NWP ($n \approx 10^6$)}{figure.1.8}{}}
